# Port for the Fastify server
PORT=3000

# Allowed origin for CORS (frontend dev server)
CORS_ORIGIN=http://localhost:5173

# Postgres connection string (Docker Compose default shown below)
DATABASE_URL=postgresql://tavuilu:tavuilu@localhost:5432/tavuilu

# Secret key for signing sessions (generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Base URL of this API server (used by better-auth for redirect/CORS checks)
BETTER_AUTH_URL=http://localhost:3000
