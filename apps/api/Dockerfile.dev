FROM node:22-alpine
RUN apk add --no-cache openssl
RUN npm install -g pnpm
WORKDIR /app
COPY apps/api/package.json apps/api/pnpm-lock.yaml apps/api/pnpm-workspace.yaml ./apps/api/
COPY apps/api/prisma ./apps/api/prisma/
RUN cd apps/api && pnpm install --frozen-lockfile && pnpm prisma generate
EXPOSE 3000
CMD ["sh", "-c", "cd apps/api && pnpm install --frozen-lockfile && pnpm prisma generate && pnpm prisma db push --accept-data-loss && pnpm dev"]
